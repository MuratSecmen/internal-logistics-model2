def load_common_data():
    veh_df  = normalize_columns(pd.read_excel(os.path.join(INPUT_DIR, "vehicles.xlsx")))
    dist_df = normalize_columns(pd.read_excel(os.path.join(INPUT_DIR, "distances - dakika.xlsx")))

    vehicle_col = find_first_matching_column(veh_df, ["vehicle_id","vehicle id","arac","araç","vehicle"])
    cap_col     = find_first_matching_column(veh_df, ["capacity_m2","capacity","kapasite","alan","area_m2"])
    if vehicle_col is None or cap_col is None:
        raise ValueError(f"vehicles.xlsx kolonları bulunamadı: {veh_df.columns.tolist()}")

    row = veh_df.iloc[0]
    vehicle_id = safe_str(row[vehicle_col])
    capacity   = float(row[cap_col])

    from_col = find_first_matching_column(dist_df, ["from_node","from","kaynak","source"])
    to_col   = find_first_matching_column(dist_df, ["to_node","to","hedef","destination","dest"])
    dur_col  = find_first_matching_column(dist_df, ["duration_min","duration","sure","süre","travel_time","travel time"])
    if from_col is None or to_col is None or dur_col is None:
        raise ValueError(f"distance kolonları bulunamadı: {dist_df.columns.tolist()}")

    dist = {}
    for _, r in dist_df.iterrows():
        i = safe_str(r[from_col]); j = safe_str(r[to_col])
        if i and j: dist[(i, j)] = float(r[dur_col])

    return vehicle_id, capacity, dist

def load_products(file_name, sheet_name):
    file_path = os.path.join(INPUT_DIR, file_name)
    df = find_header_row_and_prepare_df(file_path, sheet_name)
    if df is None or df.empty:
        raise ValueError(f"{file_name}/{sheet_name} okunamadı.")

    pid_col    = find_first_matching_column(df, ["product_id","product id","parça","parca","id","ürün","urun"])
    origin_col = find_first_matching_column(df, ["origin","from","kaynak","source","çıkış","cikis"])
    dest_col   = find_first_matching_column(df, ["destination","to","hedef","dest","varış","varis"])
    ready_col  = find_first_matching_column(df, ["ready_time","ready time","ep","hazır_zaman","hazir_zaman","ready"])
    load_col   = find_first_matching_column(df, ["load_time","load time","slp","yükleme","yukleme","loading"])
    unload_col = find_first_matching_column(df, ["unload_time","unload time","sup","boşaltma","bosaltma","unloading"])
    area_col   = find_first_matching_column(df, ["area_m2","area","qp","m2","alan","surface_area"])

    missing = [k for k, v in {"product_id":pid_col,"origin":origin_col,"destination":dest_col,
                               "ready_time":ready_col,"load_time":load_col,"unload_time":unload_col,
                               "area":area_col}.items() if v is None]
    if missing:
        raise ValueError(f"{file_name}/{sheet_name} eksik kolonlar: {missing}. Bulunan: {df.columns.tolist()}")

    df = df.dropna(subset=[pid_col, origin_col, dest_col])
    parts = {}
    for _, r in df.iterrows():
        pid = safe_str(r[pid_col])
        if not pid: continue
        parts[pid] = {
            "origin":      safe_str(r[origin_col]),
            "destination": safe_str(r[dest_col]),
            "ready_time":  ready_to_min(r[ready_col]),
            "load_time":   float(r[load_col]),
            "unload_time": float(r[unload_col]),
            "area":        float(r[area_col]),
        }
    return parts

# =========================================================
# RT(n)  —  n düğümünde servisin en erken başlayabileceği zaman
# =========================================================
def calculate_rt(node, parts, dist):
    term1 = 0.0
    term2 = 0.0
    for p, data in parts.items():
        if data["origin"] == node:
            term1 = max(term1, max(data["ready_time"], dist.get(("h", node), 0.0)))
    for p, data in parts.items():
        if data["destination"] == node:
            o = data["origin"]
            candidate = (max(data["ready_time"], dist.get(("h", o), 0.0))
                         + data["load_time"] + dist.get((o, node), 0.0))
            term2 = max(term2, candidate)
    return max(term1, term2)

# =========================================================
# ZAMANSAL BASKI SKORU  (c2 tie-breaker)
# =========================================================
def calculate_temporal_pressure(pid, parts, dist):
    """
    Parça başına zamansal baskı skoru: pressure(p) = c(h, o_p) - e_p

    Yorumu:
      • pressure > 0:  Araç o_p'ye vardığında parça çoktan hazır olmuş,
                       bekliyor olacak. f2'ye katkı riski yüksek → ÖNCELİKLİ.
      • pressure = 0:  Mükemmel senkronizasyon.
      • pressure < 0:  Araç oraya parça hazır olmadan ulaşabilir; parça
                       beklemez, araç bekler. Sonraya bırakılabilir.

    Not: Bu bir alt sınır değil, sıralama için heuristik bir öncelik skorudur.
    """
    d = parts[pid]
    return dist.get(("h", d["origin"]), 0.0) - d["ready_time"]

# =========================================================
# ROUTE CLASS
# =========================================================
class Route:
    def __init__(self, vehicle_id, capacity, start_time):
        self.vehicle_id = vehicle_id
        self.capacity   = capacity
        self.start_time = start_time
        self.nodes      = ["h", "h"]   # başlangıç: boş rota, sadece depo
        self.parts      = set()

    def customer_nodes(self):
        # İlk ve son depo düğümlerini hariç tut
        return self.nodes[1:-1]

    def node_position(self, node):
        # Rotada düğümün pozisyonunu döndürür, yoksa -1
        for idx in range(1, len(self.nodes) - 1):
            if self.nodes[idx] == node: return idx
        return -1

    def build_node_events(self, parts):
        # Her düğümde hangi parçaların yüklenip boşaltılacağını hazırla
        node_pickups    = {n: [] for n in self.customer_nodes()}
        node_deliveries = {n: [] for n in self.customer_nodes()}
        for p in self.parts:
            o = parts[p]["origin"]; d = parts[p]["destination"]
            if o in node_pickups:    node_pickups[o].append(p)
            if d in node_deliveries: node_deliveries[d].append(p)
        return node_pickups, node_deliveries

    def simulate(self, parts, dist):
        """
        Rotayı baştan sona simüle eder; her düğümde varış/servis/ayrılış
        zamanlarını, yükü ve feasibility durumunu hesaplar.
        """
        prev_node = "h"
        td_prev   = self.start_time
        current_load = 0.0
        timeline = []
        arrivals_to_dest = {}
        node_pickups, node_deliveries = self.build_node_events(parts)

        for n in self.customer_nodes():
            ta_n = td_prev + dist.get((prev_node, n), 0.0)
            pickups_here    = sorted(node_pickups.get(n, []))
            deliveries_here = sorted(node_deliveries.get(n, []))
            unload_total = sum(parts[p]["unload_time"] for p in deliveries_here)
            load_total   = sum(parts[p]["load_time"]   for p in pickups_here)
            rt_n = calculate_rt(n, parts, dist)
            ts_n = max(ta_n, rt_n)           # servise başlama: varış veya hazır zamanın büyüğü
            td_n = ts_n + unload_total + load_total

            current_load -= sum(parts[p]["area"] for p in deliveries_here)
            current_load += sum(parts[p]["area"] for p in pickups_here)

            # Kapasite kontrolü: araçtan fazla yük binmemeli
            if current_load > self.capacity + 1e-9:
                return {
                    "feasible": False,
                    "reason":   "capacity",
                    "node":     n,
                    "load":     round(current_load, 4),
                    "capacity": self.capacity,
                    "timeline": timeline
                }

            for p in deliveries_here:
                arrivals_to_dest[p] = ta_n   # bu parçanın teslimat düğümüne varış zamanı

            service_type = []
            if deliveries_here: service_type.append("Delivery")
            if pickups_here:    service_type.append("Pickup")
            service_type = "+".join(service_type) if service_type else "None"

            timeline.append({
                "node": n, "service_type": service_type,
                "ta": ta_n, "rt": rt_n, "ts": ts_n, "td": td_n,
                "node_wait": ts_n - ta_n,
                "unload_total": unload_total, "load_total": load_total,
                "service_total": unload_total + load_total,
                "load": current_load,
                "pickups": ",".join(pickups_here),
                "deliveries": ",".join(deliveries_here),
            })
            td_prev = td_n; prev_node = n

        depot_arrival = td_prev + dist.get((prev_node, "h"), 0.0)

        # Vardiya sonu kontrolü
        if depot_arrival > SHIFT_END + 1e-9:
            return {"feasible": False, "reason": "shift",
                    "depot_arrival": depot_arrival, "limit": SHIFT_END, "timeline": timeline}

        # Öncelik kontrolü: her parçanın origin'inden önce destination'a gidilmemeli
        dep_map = {t["node"]: t["td"] for t in timeline}
        arr_map = {t["node"]: t["ta"] for t in timeline}
        for p in self.parts:
            o = parts[p]["origin"]; d = parts[p]["destination"]
            if o not in dep_map or d not in arr_map:
                return {"feasible": False, "reason": "missing_visit", "part": p}
            if arr_map[d] + 1e-9 < dep_map[o]:
                return {"feasible": False, "reason": "precedence", "part": p,
                        "origin": o, "destination": d}

        # Sonraki düğüme seyahat bilgisini ekle (raporlama için)
        for idx in range(len(timeline)):
            if idx < len(timeline) - 1:
                next_node    = timeline[idx+1]["node"]
                next_arrival = timeline[idx+1]["ta"]
            else:
                next_node    = "h"
                next_arrival = depot_arrival
            timeline[idx]["next_node"]       = next_node
            timeline[idx]["next_arrival"]    = next_arrival
            timeline[idx]["travel_to_next"]  = next_arrival - timeline[idx]["td"]

        return {"feasible": True, "timeline": timeline,
                "arrivals_to_dest": arrivals_to_dest, "depot_arrival": depot_arrival}

    def _calc_distance_increase_insert_two(self, i, j, o, d, dist):
        """
        İki düğüm (o ve d) aynı anda eklendiğinde toplam mesafe artışı.
        Önce o'yu i'ye, sonra d'yi j'ye eklemenin marjinal maliyeti.
        """
        r = self.nodes
        delta_o = (dist.get((r[i-1], o), 0.0) + dist.get((o, r[i]), 0.0)
                   - dist.get((r[i-1], r[i]), 0.0))
        tmp     = r[:i] + [o] + r[i:]
        delta_d = (dist.get((tmp[j-1], d), 0.0) + dist.get((d, tmp[j]), 0.0)
                   - dist.get((tmp[j-1], tmp[j]), 0.0))
        return delta_o + delta_d

    def _calc_distance_increase_insert_one(self, pos, node, dist):
        """Tek düğüm eklendiğinde mesafe artışı."""
        r = self.nodes
        return (dist.get((r[pos-1], node), 0.0) + dist.get((node, r[pos]), 0.0)
                - dist.get((r[pos-1], r[pos]), 0.0))

    def calc_c1(self, trial_route, distance_cost, parts, dist, alpha1=None, alpha2=None, alpha3=None):
        """
        c1 insertion cost: alpha1*Δd + alpha2*ΔT + alpha3*ΔW
          Δd  = mesafe artışı
          ΔT  = rota süresi artışı (f1'deki değişim)
          ΔW  = toplam bekleme artışı (f2'deki değişim)
        Hangi hedefe odaklanmak istediğimize göre alpha'lar ayarlanır.
        """
        if alpha1 is None:
            alpha1, alpha2, alpha3, _ = ALPHA_CONFIGS[0]
        old_sim = self.simulate(parts, dist)
        if not old_sim["feasible"]: return float("inf")
        new_sim = trial_route.simulate(parts, dist)
        if not new_sim["feasible"]: return float("inf")

        old_f1  = old_sim["depot_arrival"] - self.start_time
        new_f1  = new_sim["depot_arrival"] - self.start_time
        delta_T = max(0.0, new_f1 - old_f1)

        old_f2 = sum(max(0.0, old_sim["arrivals_to_dest"].get(p, 0)
                         + parts[p]["unload_time"] - parts[p]["ready_time"])
                     for p in old_sim["arrivals_to_dest"])
        new_f2 = sum(max(0.0, new_sim["arrivals_to_dest"].get(p, 0)
                         + parts[p]["unload_time"] - parts[p]["ready_time"])
                     for p in new_sim["arrivals_to_dest"])
        delta_W = new_f2 - old_f2

        return alpha1 * distance_cost + alpha2 * delta_T + alpha3 * delta_W

    def try_insert(self, pid, parts, dist, alpha1=None, alpha2=None, alpha3=None, debug=False):
        """
        Parçayı rotaya eklemenin en ucuz feasible pozisyonunu bulur.
        Dört durum mümkün:
          A: origin ve destination her ikisi de rotada yok  → ikisini birden ekle
          B: origin var, destination yok                    → sadece destination ekle
          C: destination var, origin yok                    → sadece origin ekle
          D: ikisi de zaten var                             → sadece parçayı kaydet
        """
        if alpha1 is None:
            alpha1, alpha2, alpha3, _ = ALPHA_CONFIGS[0]
        o = parts[pid]["origin"]; d = parts[pid]["destination"]
        o_pos = self.node_position(o); d_pos = self.node_position(d)
        best_cost = float("inf"); best_spec = None

        if o_pos >= 0 and d_pos >= 0:                       # Durum D
            if o_pos < d_pos:
                trial = copy.deepcopy(self); trial.parts.add(pid)
                sim = trial.simulate(parts, dist)
                if sim["feasible"]:
                    best_cost = 0.0; best_spec = {"case": "D"}
            return best_cost, best_spec

        if o_pos < 0 and d_pos < 0:                         # Durum A
            for i in range(1, len(self.nodes)):
                for j in range(i+1, len(self.nodes)+1):
                    trial = copy.deepcopy(self)
                    trial.nodes.insert(i, o); trial.nodes.insert(j, d); trial.parts.add(pid)
                    sim = trial.simulate(parts, dist)
                    if not sim["feasible"]: continue
                    dist_cost = self._calc_distance_increase_insert_two(i, j, o, d, dist)
                    c1 = self.calc_c1(trial, dist_cost, parts, dist, alpha1, alpha2, alpha3)
                    if c1 < best_cost:
                        best_cost = c1; best_spec = {"case": "A", "i": i, "j": j}
            return best_cost, best_spec

        if o_pos >= 0 and d_pos < 0:                        # Durum B
            for j in range(o_pos+1, len(self.nodes)+1):
                trial = copy.deepcopy(self); trial.nodes.insert(j, d); trial.parts.add(pid)
                sim = trial.simulate(parts, dist)
                if not sim["feasible"]: continue
                dist_cost = self._calc_distance_increase_insert_one(j, d, dist)
                c1 = self.calc_c1(trial, dist_cost, parts, dist, alpha1, alpha2, alpha3)
                if c1 < best_cost:
                    best_cost = c1; best_spec = {"case": "B", "j": j}
            return best_cost, best_spec

        if o_pos < 0 and d_pos >= 0:                        # Durum C
            for i in range(1, d_pos+1):
                trial = copy.deepcopy(self); trial.nodes.insert(i, o); trial.parts.add(pid)
                sim = trial.simulate(parts, dist)
                if not sim["feasible"]: continue
                dist_cost = self._calc_distance_increase_insert_one(i, o, dist)
                c1 = self.calc_c1(trial, dist_cost, parts, dist, alpha1, alpha2, alpha3)
                if c1 < best_cost:
                    best_cost = c1; best_spec = {"case": "C", "i": i}
            return best_cost, best_spec

        return best_cost, best_spec

    def apply(self, pid, spec, parts):
        self.parts.add(pid)
        case = spec["case"]
        if case == "A":
            self.nodes.insert(spec["i"], parts[pid]["origin"])
            self.nodes.insert(spec["j"], parts[pid]["destination"])
        elif case == "B":
            self.nodes.insert(spec["j"], parts[pid]["destination"])
        elif case == "C":
            self.nodes.insert(spec["i"], parts[pid]["origin"])
        # case D: düğümler zaten rotada, ek işlem yok

# =========================================================
# 2-OPT LOCAL SEARCH
# =========================================================
def two_opt(route, parts, dist, alpha1, alpha2, alpha3):
    """
    İnşaat sonrası çapraz yayları düzelterek rotayı iyileştirir.

    Fikir: rotadaki i+1..j segmentini tersine çevir; eğer skor düşüyorsa kabul et.
    Feasibility bozuluyorsa (öncelik, kapasite, vardiya) bu swap atlanır.
    İyileşme kalmayınca durur (first-improvement: ilk iyi swap'ta sıfırdan tarar).
    """
    improved = True
    while improved:
        improved = False
        sim_curr = route.simulate(parts, dist)
        if not sim_curr["feasible"]:
            break

        # Alpha-ağırlıklı bileşik skor: alpha2*f1 + alpha3*f2
        curr_f1 = sim_curr["depot_arrival"] - route.start_time
        curr_f2 = sum(max(0.0, sim_curr["arrivals_to_dest"].get(p, 0)
                          + parts[p]["unload_time"] - parts[p]["ready_time"])
                      for p in sim_curr["arrivals_to_dest"])
        curr_score = alpha2 * curr_f1 + alpha3 * curr_f2

        n = len(route.nodes)
        for i in range(1, n - 2):          # i >= 1: ilk depo hariç
            for j in range(i + 2, n - 1):  # j <= n-2: son depo hariç, en az 2 boşluk
                trial = copy.deepcopy(route)
                trial.nodes[i+1:j+1] = trial.nodes[i+1:j+1][::-1]   # segmenti tersine çevir
                sim_trial = trial.simulate(parts, dist)
                if not sim_trial["feasible"]:
                    continue
                trial_f1 = sim_trial["depot_arrival"] - trial.start_time
                trial_f2 = sum(max(0.0, sim_trial["arrivals_to_dest"].get(p, 0)
                                   + parts[p]["unload_time"] - parts[p]["ready_time"])
                               for p in sim_trial["arrivals_to_dest"])
                trial_score = alpha2 * trial_f1 + alpha3 * trial_f2
                if trial_score < curr_score - 1e-9:
                    route = trial
                    improved = True
                    break
            if improved:
                break
    return route

# =========================================================
# OR-OPT-ON-PAIRS LOCAL SEARCH
# =========================================================
def or_opt_on_pairs(route, parts, dist, alpha1, alpha2, alpha3):
    """
    Parça bazlı yeniden yerleştirme: her p için (o_p, d_p) çiftini
    rotadan söküp tüm geçerli (i, j) pozisyonlarına yeniden ekler.

    2-opt'un yakalayamadığı erken açgözlü hataları düzeltir; özellikle
    yanlış sıraya girmiş parçaları doğru yere taşır.
    First-improvement: ilk iyileşmede sıfırdan tara.
    """
    improved = True
    while improved:
        improved = False
        sim_curr = route.simulate(parts, dist)
        if not sim_curr["feasible"]:
            break

        curr_f1 = sim_curr["depot_arrival"] - route.start_time
        curr_f2 = sum(max(0.0, sim_curr["arrivals_to_dest"].get(p, 0)
                          + parts[p]["unload_time"] - parts[p]["ready_time"])
                      for p in sim_curr["arrivals_to_dest"])
        curr_score = alpha2 * curr_f1 + alpha3 * curr_f2

        for p in sorted(route.parts):
            o = parts[p]["origin"]
            d = parts[p]["destination"]

            # o ve d'yi rotadan çıkar; kalan rota = "base"
            base = copy.deepcopy(route)
            base.nodes = [n for n in base.nodes if n != o and n != d]
            base.parts.discard(p)

            best_trial_score = curr_score
            best_trial_route = None

            # base rotadaki tüm (i, j) çiftlerine yeniden yerleştirmeyi dene
            m = len(base.nodes)
            for i in range(1, m):
                for j in range(i + 1, m + 1):
                    trial = copy.deepcopy(base)
                    trial.nodes.insert(i, o)
                    trial.nodes.insert(j, d)
                    trial.parts.add(p)
                    sim_trial = trial.simulate(parts, dist)
                    if not sim_trial["feasible"]:
                        continue
                    trial_f1 = sim_trial["depot_arrival"] - trial.start_time
                    trial_f2 = sum(max(0.0, sim_trial["arrivals_to_dest"].get(q, 0)
                                       + parts[q]["unload_time"] - parts[q]["ready_time"])
                                   for q in sim_trial["arrivals_to_dest"])
                    trial_score = alpha2 * trial_f1 + alpha3 * trial_f2
                    if trial_score < best_trial_score - 1e-9:
                        best_trial_score = trial_score
                        best_trial_route = trial

            if best_trial_route is not None:
                route = best_trial_route
                improved = True
                break   # iyileşme bulundu, tüm parçaları sıfırdan tara

    return route

# =========================================================
# OBJECTIVE COMPUTATION
# =========================================================
def compute_f1(sim_result):
    """f1 = toplam rota süresi (depodan depoya)"""
    return sim_result["depot_arrival"] - SHIFT_START

def compute_f2(parts, sim_result):
    """
    f2 = sum( max(0, ta_{d_p} + su_p - e_p) )
    Her parça için teslimat noktasına varış + boşaltma süresi, ready_time'ı
    ne kadar aşıyor? Aşım = o parçanın bekleme maliyeti.
    """
    total_wait = 0.0
    waits      = {}
    for p, ta_dp in sim_result["arrivals_to_dest"].items():
        ep = parts[p]["ready_time"]
        su = parts[p]["unload_time"]
        w  = max(0.0, ta_dp + su - ep)
        waits[p]    = w
        total_wait += w
    return total_wait, waits

# =========================================================
# MILP-FORMAT VARIABLE EXTRACTION
# =========================================================
def extract_milp_vars(route, parts, dist, sim, k, r=1):
    timeline  = sim["timeline"]
    nodes_seq = route.nodes

    f2_total, waits = compute_f2(parts, sim)

    x_list = [{"var":"x","i":nodes_seq[idx],"j":nodes_seq[idx+1],"k":k,"r":r,"val":1}
               for idx in range(len(nodes_seq)-1)]

    f_list = [{"var":"f","p":p,"k":k,"r":r,"val":1} for p in sorted(route.parts)]

    u_list = [{"var":"u","j":row["node"],"k":k,"r":r,"u":idx}
               for idx, row in enumerate(timeline, 1)]

    z_list = [{"var":"z","k":k,"r":r,"z":1 if timeline else 0}]

    w_list = [{"var":"w","p":p,"k":k,"r":r,
               "w_val": waits.get(p, 0.0),
               "ta_dp": sim["arrivals_to_dest"].get(p, None),
               "su_p":  parts[p]["unload_time"],
               "ep":    parts[p]["ready_time"]}
              for p in sorted(route.parts)]

    ta_list = [{"var":"ta","node":"h","k":k,"r":r,
                "time":sim["depot_arrival"],"stamp":minutes_to_hhmm(sim["depot_arrival"])}]
    td_list = [{"var":"td","node":"h","k":k,"r":r,
                "time":route.start_time,"stamp":minutes_to_hhmm(route.start_time)}]
    ts_list = []
    for row in timeline:
        n = row["node"]
        ta_list.append({"var":"ta","node":n,"k":k,"r":r,"time":row["ta"],"stamp":minutes_to_hhmm(row["ta"])})
        td_list.append({"var":"td","node":n,"k":k,"r":r,"time":row["td"],"stamp":minutes_to_hhmm(row["td"])})
        ts_list.append({"var":"ts","node":n,"k":k,"r":r,"time":row["ts"],"stamp":minutes_to_hhmm(row["ts"])})

    y_list = [{"var":"y","node":"h","k":k,"r":r,"y_val":0.0}]
    for row in timeline:
        y_list.append({"var":"y","node":row["node"],"k":k,"r":r,"y_val":row["load"]})

    node_pickup_area   = {n: sum(parts[p]["area"] for p in route.parts if parts[p]["origin"]==n)
                           for n in route.customer_nodes()}
    node_delivery_area = {n: sum(parts[p]["area"] for p in route.parts if parts[p]["destination"]==n)
                           for n in route.customer_nodes()}
    delta_list = [{"var":"delta","node":row["node"],"k":k,"r":r,
                   "delta_val": node_pickup_area.get(row["node"],0.0) - node_delivery_area.get(row["node"],0.0)}
                  for row in timeline]

    itinerary_list = [{"k":k,"r":r,"j":row["node"],"u":idx,
                        "ta_stamp":minutes_to_hhmm(row["ta"]),
                        "td_stamp":minutes_to_hhmm(row["td"]),
                        "y_after":row["load"]}
                       for idx, row in enumerate(timeline, 1)]

    return {"x":x_list,"f":f_list,"u":u_list,"z":z_list,"w":w_list,
            "ta":ta_list,"td":td_list,"ts":ts_list,"y":y_list,
            "delta":delta_list,"itinerary":itinerary_list}

