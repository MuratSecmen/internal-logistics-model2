# EXCEL WRITER
# =========================================================
def write_milp_format_excel(output_path, file_name, sheet_name,
                             route, parts, dist, sim, vehicle_id, f1, f2,
                             alpha_label="f1_bias"):
    k = vehicle_id; r = 1
    vars_ = extract_milp_vars(route, parts, dist, sim, k=k, r=r)

    df_opt = pd.DataFrame([{
        "model":               "heuristic_solomon_i1_pdp_v3",
        "alpha_config":        alpha_label,
        "f1_route_time":       f1,
        "f2_total_wait":       f2,
        "f2_definition":       "sum(max(0, ta_dp + su_p - ep))",
        "depot_arrival":       sim["depot_arrival"],
        "depot_arrival_stamp": minutes_to_hhmm(sim["depot_arrival"]),
        "status":              "HEURISTIC",
        "instance_file":       file_name,
        "instance_sheet":      sheet_name,
        "|P|":                 len(parts),
        "|Nw|":                len(set(route.customer_nodes())),
        "SHIFT_START":         SHIFT_START,
        "SHIFT_END":           SHIFT_END,
        "LAMBDA_C2":           LAMBDA_C2,
        "vehicle_capacity":    route.capacity,
        "tie_break_rule":      "c2 -> pressure -> c1 -> part_index",
        "local_search":        "2-opt + or-opt-on-pairs",
    }])

    _cols = {
        "x":         ["var","i","j","k","r","val"],
        "f":         ["var","p","k","r","val"],
        "u":         ["var","j","k","r","u"],
        "z":         ["var","k","r","z"],
        "w":         ["var","p","k","r","w_val","ta_dp","su_p","ep"],
        "ta":        ["var","node","k","r","time","stamp"],
        "td":        ["var","node","k","r","time","stamp"],
        "ts":        ["var","node","k","r","time","stamp"],
        "y":         ["var","node","k","r","y_val"],
        "delta":     ["var","node","k","r","delta_val"],
        "itinerary": ["k","r","j","u","ta_stamp","td_stamp","y_after"],
    }
    dfs = {key: pd.DataFrame(vars_[key]) if vars_[key]
           else pd.DataFrame(columns=_cols[key]) for key in _cols}

    with pd.ExcelWriter(output_path, engine="openpyxl") as writer:
        df_opt.to_excel(writer, sheet_name="optimization_results", index=False)
        dfs["x"].to_excel(writer, sheet_name="x_ijkr", index=False)
        dfs["f"].to_excel(writer, sheet_name="f_pkr", index=False)
        dfs["u"].to_excel(writer, sheet_name="u_jkr", index=False)
        dfs["z"].to_excel(writer, sheet_name="z_kr", index=False)
        dfs["w"].to_excel(writer, sheet_name="w_p", index=False)
        dfs["ta"].to_excel(writer, sheet_name="ta", index=False)
        dfs["td"].to_excel(writer, sheet_name="td", index=False)
        dfs["ts"].to_excel(writer, sheet_name="ts", index=False)
        dfs["y"].to_excel(writer, sheet_name="y_jkr", index=False)
        dfs["delta"].to_excel(writer, sheet_name="delta_jkr", index=False)
        dfs["itinerary"].to_excel(writer, sheet_name="itinerary", index=False)

    print(f"  → Excel (12 sheets) → {output_path}")
    print(f"      f1={f1:.2f}  f2={f2:.2f}  |  arcs={len(dfs['x'])}  parts={len(dfs['f'])}")

# =========================================================
# SOLOMON I1 INSAATI + LOCAL SEARCH  (tek alpha config için)
# =========================================================
def build_and_polish(parts, vehicle_id, capacity, dist,
                     alpha1, alpha2, alpha3, debug=False):
    """
    1) Solomon I1 ile rota inşa et.
    2) 2-opt ile segment terslemesi yap.
    3) Or-opt-on-pairs ile parça bazlı yeniden yerleştir.
    """
    unrouted = set(parts.keys())
    route    = Route(vehicle_id, capacity, SHIFT_START)

    # Tie-breaking kaç kez devreye girdi? (sadece raporlama için)
    n_tie_pressure = 0
    n_tie_c1       = 0
    n_tie_index    = 0

    # ── Solomon I1 Construction ──────────────────────────────────
    while unrouted:
        best_choice   = None
        best_c2       = -float("inf")
        best_pressure = -float("inf")
        best_c1       = float("inf")
        best_pid      = None

        for p in sorted(unrouted):
            c1, spec = route.try_insert(p, parts, dist,
                                        alpha1=alpha1, alpha2=alpha2, alpha3=alpha3,
                                        debug=debug)
            if spec is None:
                continue

            # c2: depodan uzaklık ne kadar avantajlı, eklenme maliyeti ne kadar pahalı
            c2       = LAMBDA_C2 * dist.get(("h", parts[p]["origin"]), 0.0) - c1
            pressure = calculate_temporal_pressure(p, parts, dist)

            # Tie-breaking zinciri: c2 > pressure > c1 > part_index
            is_better = False
            tie_kind  = None
            if c2 > best_c2 + 1e-9:
                is_better = True
            elif abs(c2 - best_c2) < 1e-9:
                if pressure > best_pressure + 1e-9:
                    is_better = True; tie_kind = "pressure"
                elif abs(pressure - best_pressure) < 1e-9:
                    if c1 < best_c1 - 1e-9:
                        is_better = True; tie_kind = "c1"
                    elif abs(c1 - best_c1) < 1e-9 and (best_pid is None or p < best_pid):
                        is_better = True; tie_kind = "index"

            if is_better:
                if tie_kind == "pressure": n_tie_pressure += 1
                elif tie_kind == "c1":     n_tie_c1       += 1
                elif tie_kind == "index":  n_tie_index    += 1
                best_c2       = c2
                best_pressure = pressure
                best_c1       = c1
                best_pid      = p
                best_choice   = (p, spec, c1, c2, pressure)

        if best_choice is None:
            print(f"  ✗ Unrouted: {unrouted}"); break
        p, spec, c1_val, c2_val, pr_val = best_choice
        route.apply(p, spec, parts)
        unrouted.remove(p)
        print(f"    → inserted {p}  case={spec['case']}  "
              f"c1={c1_val:.2f}  c2={c2_val:.2f}  pressure={pr_val:.2f}")

    print(f"\n  Tie-break istatistiği: pressure={n_tie_pressure}  "
          f"c1={n_tie_c1}  index={n_tie_index}")
    print(f"  Route (inşaat): {' → '.join(route.nodes)}")

    # ── 2-opt ───────────────────────────────────────────────────
    pre_sim = route.simulate(parts, dist)
    pre_f1  = compute_f1(pre_sim) if pre_sim["feasible"] else None
    pre_f2, _ = compute_f2(parts, pre_sim) if pre_sim["feasible"] else (None, {})
    route = two_opt(route, parts, dist, alpha1, alpha2, alpha3)
    post_sim = route.simulate(parts, dist)
    post_f1  = compute_f1(post_sim) if post_sim["feasible"] else None
    post_f2, _ = compute_f2(parts, post_sim) if post_sim["feasible"] else (None, {})
    print(f"  2-opt:         f1: {pre_f1} → {post_f1}   f2: {pre_f2} → {post_f2}")

    # ── Or-opt-on-pairs ─────────────────────────────────────────
    pre_sim = route.simulate(parts, dist)
    pre_f1  = compute_f1(pre_sim) if pre_sim["feasible"] else None
    pre_f2, _ = compute_f2(parts, pre_sim) if pre_sim["feasible"] else (None, {})
    route = or_opt_on_pairs(route, parts, dist, alpha1, alpha2, alpha3)
    post_sim = route.simulate(parts, dist)
    post_f1  = compute_f1(post_sim) if post_sim["feasible"] else None
    post_f2, _ = compute_f2(parts, post_sim) if post_sim["feasible"] else (None, {})
    print(f"  Or-opt-pairs:  f1: {pre_f1} → {post_f1}   f2: {pre_f2} → {post_f2}")

    return route

# =========================================================
# SOLVER
# =========================================================
def solve_file(file_name, vehicle_id, capacity, dist, debug=False):
    xl     = pd.ExcelFile(os.path.join(INPUT_DIR, file_name))
    os.makedirs(OUTPUT_DIR, exist_ok=True)
    ts_tag = datetime.now().strftime('%Y%m%d_%H%M%S')

    for sheet in xl.sheet_names:
        print(f"\n{'='*60}")
        print(f"  SOLVING: {file_name} | {sheet}")
        print(f"{'='*60}")

        parts = load_products(file_name, sheet)

        # Her alpha konfigürasyonu için ayrı çözüm üret
        configs_to_run = ALPHA_CONFIGS if MULTI_DECODE else [ALPHA_CONFIGS[0]]

        for alpha1, alpha2, alpha3, label in configs_to_run:
            print(f"\n  ── Alpha config: {label}  "
                  f"(α1={alpha1}, α2={alpha2}, α3={alpha3}) ──")

            route = build_and_polish(parts, vehicle_id, capacity, dist,
                                     alpha1, alpha2, alpha3, debug=debug)

            print(f"  Route (final):   {' → '.join(route.nodes)}")
            sim = route.simulate(parts, dist)

            if sim["feasible"]:
                f1        = compute_f1(sim)
                f2, waits = compute_f2(parts, sim)
                print(f"  f1 = {f1:.2f} dk  |  f2 = {f2:.2f} dk  |  depot = {minutes_to_hhmm(sim['depot_arrival'])}")
                print(f"  Parça bekleme detayı (w_p = ta_dp + su_p - ep):")
                for p, w in sorted(waits.items()):
                    ta_dp = sim["arrivals_to_dest"].get(p, 0)
                    su    = parts[p]["unload_time"]
                    ep    = parts[p]["ready_time"]
                    print(f"    {p}: ta_dp={ta_dp:.1f}  su={su:.1f}  ep={ep:.0f}  → w={w:.2f}")

                safe_sheet = sheet.replace("/","_").replace("\\","_").replace(" ","_")
                safe_file  = file_name.replace(".xlsx","").replace(" ","_")
                excel_path = os.path.join(
                    OUTPUT_DIR,
                    f"heuristic_{safe_file}_{safe_sheet}_{label}_{ts_tag}.xlsx"
                )
                write_milp_format_excel(excel_path, file_name, sheet, route, parts, dist, sim,
                                        vehicle_id, f1, f2, alpha_label=label)
            else:
                reason = sim.get("reason")
                if reason == "capacity":
                    print(f"  ✗ INFEASIBLE — kapasite aşımı: "
                          f"node={sim.get('node')}  "
                          f"load={sim.get('load')} > capacity={sim.get('capacity')}")
                elif reason == "shift":
                    print(f"  ✗ INFEASIBLE — vardiya aşımı: "
                          f"depot_arrival={sim.get('depot_arrival'):.2f} > {SHIFT_END}")
                elif reason == "precedence":
                    print(f"  ✗ INFEASIBLE — precedence ihlali: "
                          f"part={sim.get('part')}  "
                          f"origin={sim.get('origin')} → dest={sim.get('destination')}")
                elif reason == "missing_visit":
                    print(f"  ✗ INFEASIBLE — eksik ziyaret: part={sim.get('part')}")
                else:
                    print(f"  ✗ INFEASIBLE — reason={reason}  detail={sim}")

