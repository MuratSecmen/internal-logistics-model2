# ENTRY POINT
# =========================================================
def run_all(debug=False):
    vehicle_id, capacity, dist = load_common_data()
    print(f"Vehicle: {vehicle_id}  |  Capacity: {capacity} m²")
    print(f"f2 tanımı: w_p = max(0, ta_dp + su_p - ep)")
    print(f"Tie-break: c2 > pressure > c1 > part_index")
    print(f"Local search: 2-opt + or-opt-on-pairs")
    print(f"Multi-decode: {MULTI_DECODE}  |  Alpha configs: {[c[3] for c in ALPHA_CONFIGS]}")
    print(f"Output: {OUTPUT_DIR}\n")

    for f in FILES:
        if not os.path.exists(os.path.join(INPUT_DIR, f)):
            print(f"  Dosya bulunamadı, atlanıyor: {f}"); continue
        solve_file(f, vehicle_id, capacity, dist, debug=debug)

    print("\n" + "="*60)
    print(f"TAMAMLANDI — çıktı klasörünü kontrol et: {OUTPUT_DIR}")
    print("="*60)

if __name__ == "__main__":
    run_all(debug=False)
