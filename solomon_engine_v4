def compute_rt(parts):
    nodes = set()
    for p in parts: nodes.add(p['o']); nodes.add(p['d'])
    rt = {}
    for n in nodes:
        pv = [max(p['r'], t('h',n)) for p in parts if p['o']==n]
        dv = [max(p['r'], t('h',p['o'])) + S + t(p['o'],n) for p in parts if p['d']==n]
        c = []
        if pv: c.append(max(pv))
        if dv: c.append(max(dv))
        rt[n] = max(c) if c else 0
    return rt

def ninfo(n, parts):
    lds = [p['id'] for p in parts if p['o']==n]
    uls = [p['id'] for p in parts if p['d']==n]
    tp = 'karma' if lds and uls else ('saf_pickup' if lds else 'saf_delivery')
    ops = [f'unload {u}' for u in uls] + [f'load {l}' for l in lds]
    return {'type':tp,'loads':lds,'unloads':uls,'S':(len(lds)+len(uls))*S,'ops':', '.join(ops)}

def c11(i,u,j): return t(i,u)+t(u,j)-MU*t(i,j)

# ─── INDEX-BASED INSERTION (fixes h-ambiguity bug) ───
def best_insert(route, part):
    """Returns (C1, pick_idx_or_consol, del_idx_or_consol)
    pick_idx: index in route BEFORE which to insert o (or 'C' for consolidation)
    del_idx: index in EXPANDED route before which to insert d (or 'C')
    """
    o, d = part['o'], part['d']
    o_in = o in route[1:-1]  # exclude depot positions
    d_in = d in route[1:-1]
    best = float('inf')
    bp = bd = None

    if o_in:
        p_opts = [('C', 0)]
    else:
        p_opts = []
        for i in range(len(route)-1):
            p_opts.append((i+1, c11(route[i], o, route[i+1])))

    for pidx, cp in p_opts:
        if pidx == 'C':
            trial = list(route)
            oi = trial.index(o)
        else:
            trial = list(route)
            trial.insert(pidx, o)
            oi = pidx

        if d_in:
            tot = cp + 0
            if tot < best:
                best, bp, bd = tot, pidx, 'C'
        else:
            for j in range(oi, len(trial)-1):
                cd = c11(trial[j], d, trial[j+1])
                tot = cp + cd
                if tot < best:
                    best = tot
                    bp = pidx
                    bd = j + 1  # insert d BEFORE this index in trial

    return best, bp, bd

def do_insert(route, part, pidx, didx):
    r = list(route)
    o, d = part['o'], part['d']
    # Pickup
    if pidx != 'C' and o not in r[1:-1]:
        r.insert(pidx, o)
        # adjust didx if it was computed on the trial with o inserted
        # didx is already relative to the expanded route, so no adjustment needed
    # Delivery
    if didx != 'C' and d not in r[1:-1]:
        r.insert(didx, d)
    return r

def simulate(route, parts, rt):
    tl = []
    cur = 0
    for i, nd in enumerate(route):
        if i == 0:
            tl.append({'node':'h','a':0,'RT':'-','b':0,'S':0,'dep':0,
                       'type':'depot','ops':'start','wait':0})
            continue
        a = cur + t(route[i-1], nd)
        if nd == 'h':
            tl.append({'node':'h','a':a,'RT':'-','b':a,'S':0,'dep':a,
                       'type':'depot','ops':'return','wait':0})
            break
        ni = ninfo(nd, parts)
        rtn = rt.get(nd, 0)
        b = max(a, rtn)
        dep = b + ni['S']
        tl.append({'node':nd,'a':a,'RT':rtn,'b':b,'S':ni['S'],'dep':dep,
                   'type':ni['type'],'ops':ni['ops'],'wait':b-a})
        cur = dep
    return tl

def calc_f2(tl, parts):
    dt = {}
    for e in tl:
        for p in parts:
            if p['d'] == e['node']:
                dt[p['id']] = e['b']
    return sum(dt.get(p['id'],0)-p['r'] for p in parts), dt

def run_case(name, case):
    parts = case['parts']
    rt = compute_rt(parts)
    print(f"\n{'='*70}")
    print(f"  {name}: {case['title']}")
    print(f"{'='*70}")
    print(f"\n  {'ID':>4} {'o':>4} {'d':>4} {'r':>4}")
    for p in parts: print(f"  {p['id']:>4} {p['o']:>4} {p['d']:>4} {p['r']:>4}")
    print(f"\n  {'Düğüm':>6} {'Tip':<14} {'Ops':<30} {'RT':>4} {'S':>4}")
    for n in sorted(rt.keys()):
        ni = ninfo(n, parts)
        print(f"  {n:>6} {ni['type']:<14} {ni['ops']:<30} {rt[n]:>4} {ni['S']:>4}")

    seed = max(parts, key=lambda p: t('h',p['o']))
    route = ['h', seed['o'], seed['d'], 'h']
    routed = {seed['id']}
    print(f"\n  Seed: {seed['id']} (t(h,{seed['o']})={t('h',seed['o'])})")
    print(f"  Rota: {' → '.join(route)}")

    it = 0
    while len(routed) < len(parts):
        it += 1
        unr = [p for p in parts if p['id'] not in routed]
        print(f"\n  --- İterasyon {it} ---")
        cands = []
        for p in unr:
            c1, pp, dp = best_insert(route, p)
            c2 = LAMBDA * t('h', p['o']) - c1
            ps = "konsol." if pp=='C' else f"idx={pp}"
            ds = "konsol." if dp=='C' else f"idx={dp}"
            print(f"    {p['id']}: C1={c1:>4}, t(h,{p['o']})={t('h',p['o'])}, "
                  f"C2={c2:>4} | P:{ps} D:{ds}")
            cands.append({'p':p,'C1':c1,'C2':c2,'pp':pp,'dp':dp})

        best = max(cands, key=lambda x: x['C2'])
        routed.add(best['p']['id'])
        route = do_insert(route, best['p'], best['pp'], best['dp'])
        print(f"  → {best['p']['id']} (C2={best['C2']})")
        print(f"  Rota: {' → '.join(route)}")

    tl = simulate(route, parts, rt)
    print(f"\n  {'Düğüm':>6} {'Tip':<14} {'Ops':<28} {'a':>4} {'RT':>4} "
          f"{'b':>4} {'S':>3} {'bek':>4} {'dep':>4}")
    print(f"  {'-'*76}")
    for e in tl:
        rs = str(e['RT']) if e['RT']!='-' else '-'
        ws = str(e['wait']) if e['wait'] else ''
        print(f"  {e['node']:>6} {e['type']:<14} {e['ops']:<28} "
              f"{e['a']:>4} {rs:>4} {e['b']:>4} {e['S']:>3} {ws:>4} {e['dep']:>4}")

    f1 = tl[-1]['a']
    f2, dt = calc_f2(tl, parts)
    print(f"\n  f1={f1} dk, f2={f2} dk")
    for p in parts:
        d = dt.get(p['id'],'-')
        soj = d-p['r'] if isinstance(d,(int,float)) else '?'
        print(f"    {p['id']}: del={d}, r={p['r']}, soj={soj}")
    return {'route':route,'tl':tl,'rt':rt,'f1':f1,'f2':f2,'parts':parts,'title':case['title']}


# ─── OUTPUT EXCEL ────────────────────────────────────────────
def make_excel(results):
    wb = Workbook()
    hf = Font(bold=True, color='FFFFFF', size=10)
    hfl = PatternFill('solid', fgColor='2B579A')
    gf = PatternFill('solid', fgColor='C6EFCE')
    rf = PatternFill('solid', fgColor='FFC7CE')
    yf = PatternFill('solid', fgColor='FFEB9C')
    mf = PatternFill('solid', fgColor='E2D6F3')
    thin = Border(left=Side('thin'),right=Side('thin'),top=Side('thin'),bottom=Side('thin'))
    first = True
    for cn, res in results.items():
        ws = wb.active if first else wb.create_sheet(); ws.title = cn; first = False
        parts = res['parts']
        row = 1
        ws.cell(row,1,value=f"{cn}: {res['title']}").font = Font(bold=True,size=12)
        row = 3
        for j,h in enumerate(['Düğüm','Tip','Operasyonlar','RT(n)','S(n)']):
            c = ws.cell(row,j+1,value=h); c.font=hf; c.fill=hfl; c.border=thin
        for n in sorted(res['rt'].keys()):
            row += 1; ni = ninfo(n, parts)
            ws.cell(row,1,value=n).border=thin
            ct=ws.cell(row,2,value=ni['type']); ct.border=thin
            if ni['type']=='karma': ct.fill=mf
            ws.cell(row,3,value=ni['ops']).border=thin
            cr=ws.cell(row,4,value=res['rt'][n]); cr.border=thin
            if res['rt'][n]>15: cr.fill=rf
            cs=ws.cell(row,5,value=ni['S']); cs.border=thin
            if ni['S']>2: cs.fill=yf
        row += 2
        ws.cell(row,1,value=f"Rota: {' → '.join(res['route'])}").font=Font(bold=True,italic=True)
        row += 1
        for j,h in enumerate(['Düğüm','Tip','Operasyonlar','a','RT','b','S','Bekleme','dep']):
            c=ws.cell(row,j+1,value=h); c.font=hf; c.fill=PatternFill('solid',fgColor='00827F'); c.border=thin
        for e in res['tl']:
            row += 1
            ws.cell(row,1,value=e['node']).border=thin
            ct=ws.cell(row,2,value=e['type']); ct.border=thin
            if e['type']=='karma': ct.fill=mf
            ws.cell(row,3,value=e['ops']).border=thin
            ws.cell(row,4,value=e['a']).border=thin
            ws.cell(row,5,value=e['RT'] if e['RT']!='-' else '').border=thin
            cb=ws.cell(row,6,value=e['b']); cb.border=thin
            w=e.get('wait',0)
            if w>0: cb.fill=rf
            ws.cell(row,7,value=e['S']).border=thin
            cw=ws.cell(row,8,value=w if w>0 else ''); cw.border=thin
            if w>0: cw.fill=rf
            ws.cell(row,9,value=e['dep']).border=thin
        row += 2
        ws.cell(row,1,value='f₁').font=Font(bold=True)
        ws.cell(row,2,value=res['f1']).font=Font(bold=True,color='0000FF',size=14)
        ws.cell(row,3,value='dk')
        row += 1
        ws.cell(row,1,value='f₂').font=Font(bold=True)
        ws.cell(row,2,value=res['f2']).font=Font(bold=True,color='FF0000',size=14)
        ws.cell(row,3,value='dk')
        row += 2
        for j,h in enumerate(['Parça','del_time','r_p','sojourn']):
            c=ws.cell(row,j+1,value=h); c.font=hf; c.fill=hfl; c.border=thin
        _,dt = calc_f2(res['tl'], parts)
        for p in parts:
            row += 1; d=dt.get(p['id'],0)
            ws.cell(row,1,value=p['id']).border=thin
            ws.cell(row,2,value=d).border=thin
            ws.cell(row,3,value=p['r']).border=thin
            ws.cell(row,4,value=d-p['r']).border=thin
        widths=[10,14,30,10,10,10,8,10,10]
        for i,w in enumerate(widths):
            ws.column_dimensions[get_column_letter(i+1)].width=w

    # Karşılaştırma
    ws=wb.create_sheet('Karsilastirma')
    ws.cell(1,1,value='Karşılaştırma').font=Font(bold=True,size=14)
    row=3
    for j,h in enumerate(['Metrik']+list(results.keys())):
        c=ws.cell(row,j+1,value=h); c.font=hf; c.fill=hfl; c.border=thin
    for label,vals in [
        ('Düğüm sayısı',[len(r['rt']) for r in results.values()]),
        ('f₁ (dk)',[r['f1'] for r in results.values()]),
        ('f₂ (dk)',[r['f2'] for r in results.values()]),
        ('Rota',[' → '.join(r['route']) for r in results.values()]),
    ]:
        row += 1
        ws.cell(row,1,value=label).font=Font(bold=True); ws.cell(row,1).border=thin
        for j,v in enumerate(vals):
            c=ws.cell(row,j+2,value=v); c.border=thin
            if label=='f₁ (dk)' and isinstance(v,(int,float)):
                c.font=Font(color='0000FF')
                if v==min(x for x in vals if isinstance(x,(int,float))): c.fill=gf
            elif label=='f₂ (dk)' and isinstance(v,(int,float)):
                c.font=Font(color='FF0000')
                if v==min(x for x in vals if isinstance(x,(int,float))): c.fill=gf
    row += 2
    ws.cell(row,1,value='RT(3) Etkisi').font=Font(bold=True,size=12,color='FF0000')
    row += 1
    ws.cell(row,1,value='Case 1 (P2 tek)'); ws.cell(row,2,value=results['Case1']['rt'].get('3','-'))
    ws.cell(row,3,value='max(3,6)=6 seyahat baskın')
    row += 1
    c=ws.cell(row,2,value=results['Case3']['rt'].get('3','-')); c.fill=rf
    ws.cell(row,1,value='Case 3 (P2+P4)'); ws.cell(row,3,value='max(max(3,6),max(9,6))=9 r_p baskın')
    ws.column_dimensions['A'].width=18
    for i in range(2,10): ws.column_dimensions[get_column_letter(i)].width=14

    wb.save('/home/claude/solomon_output_v4.xlsx')
    print("\n✓ Output: solomon_output_v4.xlsx")

