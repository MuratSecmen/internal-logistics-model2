TRAVEL = np.array([
    [ 0, 4, 6, 7, 9, 8,11,10,13],
    [ 5, 0, 3, 5, 7,10, 8,12, 9],
    [ 7, 4, 0, 3, 5, 6, 4, 8,11],
    [ 8, 6, 2, 0, 4, 9, 7, 5,10],
    [10, 8, 6, 3, 0, 5, 9, 7,12],
    [ 9,11, 5, 8, 6, 0, 3, 4,14],
    [12, 9, 3, 6,10, 4, 0, 2, 7],
    [11,13, 7, 4, 8, 5, 3, 0, 6],
    [14,10,12, 9,11, 7, 8, 5, 0],
])
NI = {n: i for i, n in enumerate(NODES_ALL)}
S, MU, LAMBDA = 2, 1, 1

def t(i, j): return TRAVEL[NI[i]][NI[j]]

